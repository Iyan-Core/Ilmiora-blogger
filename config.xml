<?xml version='1.0' encoding='utf-8'?>
<widget id="com.lyancore.ilmiora" 
        version="1.0.0" 
        xmlns="http://www.w3.org/ns/widgets" 
        xmlns:cdv="http://cordova.apache.org/ns/1.0">

    <name>Ilmiora</name>
    <description>Aplikasi edukasi real-time dari ilmiora.blogspot.com</description>

    <author email="lyan@example.com" href="https://github.com/lyan-Core">
        lyan-Core
    </author>

    <!-- Entry app -->
    <content src="index.html" />

    <!-- Access -->
    <access origin="*" />
    <allow-navigation href="https://www.googleapis.com/*" />
    <allow-navigation href="https://ilmiora.blogspot.com/*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />

    <!-- UI Preferences -->
    <preference name="Orientation" value="default" />
    <preference name="Fullscreen" value="false" />
    <preference name="StatusBarOverlaysWebView" value="false" />
    <preference name="StatusBarBackgroundColor" value="#2c3e50" />
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="SplashScreenDelay" value="2000" />

    <!-- Android Config -->
    <platform name="android">

        <preference name="android-minSdkVersion" value="22" />
        <preference name="android-targetSdkVersion" value="33" />

        <!-- Icons (tanpa ldpi biar aman) -->
        <icon density="mdpi" src="res/icon/android/mdpi.png" />
        <icon density="hdpi" src="res/icon/android/hdpi.png" />
        <icon density="xhdpi" src="res/icon/android/xhdpi.png" />
        <icon density="xxhdpi" src="res/icon/android/xxhdpi.png" />
        <icon density="xxxhdpi" src="res/icon/android/xxxhdpi.png" />

    </platform>

    <!-- Plugins -->
    <plugin name="cordova-plugin-whitelist" spec="1.3.4" />
    <plugin name="cordova-plugin-advanced-http" spec="3.3.1" />
    <plugin name="cordova-plugin-local-notification" spec="1.1.0" />

</widget>
