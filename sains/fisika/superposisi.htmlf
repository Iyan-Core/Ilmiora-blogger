    <div class="art-nav-title">Taman Sains — Pilih Artikel Lain</div>
  </a>
</div>

<!-- FOOTER -->
<footer class="footer">
  <a href="https://ilmiora.blogspot.com">← ILMIORA</a>
  <span style="font-family:'Fira Code',monospace;font-size:9px;color:#333;">ILMIORA © 2025 — Where Knowledge Becomes Light</span>
</footer>
</div>

<script>
/* CANVAS */
const cvs=document.getElementById('bgCanvas'),ctx=cvs.getContext('2d');
function rsz(){cvs.width=innerWidth;cvs.height=innerHeight;}rsz();window.addEventListener('resize',rsz);
const C='#22d3ee';
const pts=Array.from({length:40},()=>({x:Math.random()*innerWidth,y:Math.random()*innerHeight,r:Math.random()*1.5+.3,vx:(Math.random()-.5)*.2,vy:(Math.random()-.5)*.2,a:Math.random()}));
(function draw(){
  ctx.clearRect(0,0,cvs.width,cvs.height);
  pts.forEach(p=>{
    p.x=(p.x+p.vx+cvs.width)%cvs.width;
    p.y=(p.y+p.vy+cvs.height)%cvs.height;
    p.a+=0.01;
    const alpha=0.15+Math.abs(Math.sin(p.a))*0.25;
    ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
    ctx.fillStyle=`${C}${Math.round(alpha*255).toString(16).padStart(2,'0')}`;
    ctx.fill();
  });
  requestAnimationFrame(draw);
})();

/* SCROLL */
window.addEventListener('scroll',()=>{document.getElementById('scrollBar').style.width=(scrollY/(document.body.scrollHeight-innerHeight)*100)+'%';});

/* AUTHOR AVATAR */
const av='Prof. Ahmad Fauzi';
const initials=(av.match(/\b\w/g)||[]).slice(0,2).join('').toUpperCase();
document.getElementById('authorAv').textContent=initials;
</script>
</body>
</html>
